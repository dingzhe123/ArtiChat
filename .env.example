# ArtiChat 环境变量配置
# 复制此文件为 .env 并填入真实值

PORT=8080
DB_PATH=data/site.db

# DeepSeek API（必填）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding 模型（可选，不支持则降级为关键词检索）
EMBEDDING_MODEL=text-embedding-ada-002

# 管理后台登录凭据
ADMIN_USER=admin
ADMIN_PASS=admin123
